+        /// <summary>
+        /// Same as <see cref="GetViewVector(float, float)"/> but writes into a caller-supplied
+        /// vector instead of allocating, for callers that run this every frame.
+        /// </summary>
+        public static void GetViewVector(float pitch, float yaw, Vec3f intoVector)
+        {
+            float cosPitch = GameMath.Cos(pitch);
+            float sinPitch = GameMath.Sin(pitch);
+
+            float cosYaw = GameMath.Cos(yaw);
+            float sinYaw = GameMath.Sin(yaw);
+
+            intoVector.Set(-cosPitch * sinYaw, sinPitch, -cosPitch * cosYaw);
+        }
