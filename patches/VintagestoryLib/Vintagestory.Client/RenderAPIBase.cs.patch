 	public void RenderMultiTextureMesh(MultiTextureMeshRef mmr, string textureSampleName, int textureNumber = 0)
 	{
+		// Optimum: guard against rendering a disposed meshref. Callers across
+		// the codebase null-check their own meshref fields before calling
+		// this, but a mesh disposed out from under an in-flight render call
+		// (a different code path releasing it the same frame) would still
+		// reach here with a non-null but disposed mmr, feeding stale/freed
+		// GL handles into plat.RenderMesh.
+		if (mmr == null || mmr.Disposed) return;
 		for (int i = 0; i < mmr.meshrefs.Length; i++)
 		{
 			MeshRef vao = mmr.meshrefs[i];
+			if (vao == null || vao.Disposed) continue;
 			CurrentActiveShader.BindTexture2D(textureSampleName, mmr.textureids[i], textureNumber);
 			plat.RenderMesh(vao);
 		}
 	}
 
