+			.AddStaticText("Limit Background FPS", CairoFont.WhiteSmallishText(), ElementBounds.Fixed(0, y0, 400, 30))
+			.AddHoverText("Cap to 20 FPS when the game window loses focus.", CairoFont.WhiteSmallText(), 250, ElementBounds.Fixed(0, y0, 400, 25))
+			.AddSwitch(onOptimumBackgroundFpsChanged, ElementBounds.Fixed(450, y0 + 2, 200, 20), "optBgFps")
+			.AddStaticText("Smooth Frame Pacing", CairoFont.WhiteSmallishText(), ElementBounds.Fixed(0, y0 + rowH, 400, 30))
+			.AddHoverText("Precise sleep/spin timing to reduce micro-stutter.", CairoFont.WhiteSmallText(), 250, ElementBounds.Fixed(0, y0 + rowH, 400, 25))
+			.AddSwitch(onOptimumFramePacingChanged, ElementBounds.Fixed(450, y0 + rowH + 2, 200, 20), "optFramePacing")
+			.AddStaticText("Skip Distant Shadows", CairoFont.WhiteSmallishText(), ElementBounds.Fixed(0, y0 + rowH * 2, 400, 30))
+			.AddHoverText("Entities beyond the threshold cast no shadow.", CairoFont.WhiteSmallText(), 250, ElementBounds.Fixed(0, y0 + rowH * 2, 400, 25))
+			.AddSwitch(onOptimumShadowCullChanged, ElementBounds.Fixed(450, y0 + rowH * 2 + 2, 200, 20), "optShadowCull")
+			.AddStaticText("Shadow Distance", CairoFont.WhiteSmallishText(), ElementBounds.Fixed(0, y0 + rowH * 3, 400, 30))
+			.AddSlider(onOptimumShadowDistChanged, ElementBounds.Fixed(450, y0 + rowH * 3 + 2, 200, 20), "optShadowDist")
+			.AddStaticText("Skip Distant Collisions", CairoFont.WhiteSmallishText(), ElementBounds.Fixed(0, y0 + rowH * 4, 400, 30))
+			.AddHoverText("Entities beyond the threshold stop pushing each other.", CairoFont.WhiteSmallText(), 250, ElementBounds.Fixed(0, y0 + rowH * 4, 400, 25))
+			.AddSwitch(onOptimumRepulsionChanged, ElementBounds.Fixed(450, y0 + rowH * 4 + 2, 200, 20), "optRepulsion")
+			.AddStaticText("Collision Distance", CairoFont.WhiteSmallishText(), ElementBounds.Fixed(0, y0 + rowH * 5, 400, 30))
+			.AddSlider(onOptimumRepulsionDistChanged, ElementBounds.Fixed(450, y0 + rowH * 5 + 2, 200, 20), "optRepulsionDist")
+			.AddStaticText("Scale Light Range", CairoFont.WhiteSmallishText(), ElementBounds.Fixed(0, y0 + rowH * 6, 400, 30))
+			.AddHoverText("Reduce the dynamic light search radius at lower view distances.", CairoFont.WhiteSmallText(), 250, ElementBounds.Fixed(0, y0 + rowH * 6, 400, 25))
+			.AddSwitch(onOptimumDynLightChanged, ElementBounds.Fixed(450, y0 + rowH * 6 + 2, 200, 20), "optDynLight")
+			.AddStaticText("Reduce Distant Animations", CairoFont.WhiteSmallishText(), ElementBounds.Fixed(0, y0 + rowH * 7, 400, 30))
+			.AddHoverText("Forges, querns, and other animated blocks skip frames when far away.", CairoFont.WhiteSmallText(), 250, ElementBounds.Fixed(0, y0 + rowH * 7, 400, 25))
+			.AddSwitch(onOptimumAnimBlockLodChanged, ElementBounds.Fixed(450, y0 + rowH * 7 + 2, 200, 20), "optAnimBlockLod")
+			.EndChildElements()
+			.Compose();
