<?xml version="1.0" encoding="utf-8"?>
<!--
  Pin nuget.org as the only package source. Without this file, NuGet inherits
  whatever the host machine configured. Visual Studio installs a machine-wide
  config whose only source is "Microsoft Visual Studio Offline Packages", and
  on such machines every restore of this solution fails with NU1101 for
  Newtonsoft.Json, protobuf-net, OpenTK, SkiaSharp, VSImGui, AnimatedGif, and
  Microsoft.Data.Sqlite.Core. The installer copies this file into its temp
  build workspace along with the rest of the source tree.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
